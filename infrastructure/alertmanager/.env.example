# Alertmanager Environment Configuration
# Copy this file to .env and fill in with actual values
# These are used by alertmanager.yml for webhook and integration endpoints

# ============================================================================
# Slack Webhooks
# ============================================================================
# Create these webhooks in your Slack workspace:
# 1. Go to https://api.slack.com/apps
# 2. Create or select your app
# 3. Enable "Incoming Webhooks"
# 4. Add New Webhook to Workspace and authorize
# 5. Copy the webhook URL for each channel

# Webhook for #incidents channel (critical alerts)
SLACK_WEBHOOK_CRITICAL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Webhook for #alerts channel (warning alerts)
SLACK_WEBHOOK_ALERTS=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Webhook for #database-alerts channel (database-specific alerts)
SLACK_WEBHOOK_DATABASE=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Webhook for #infrastructure-alerts channel (infrastructure-specific alerts)
SLACK_WEBHOOK_INFRASTRUCTURE=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Webhook for #ops-info channel (informational alerts)
SLACK_WEBHOOK_OPS_INFO=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# PagerDuty Integration
# ============================================================================
# Get your integration key from PagerDuty:
# 1. Go to https://subdomain.pagerduty.com/integrations
# 2. Create or select your integration service
# 3. Navigate to "Integrations" tab
# 4. Look for "Integration Key" (also called "Service Key")
# 5. Copy the key and paste below

# PagerDuty Service Integration Key for critical incidents
# This enables direct PagerDuty incident creation for critical alerts
PAGERDUTY_INTEGRATION_KEY=abc123def456ghi789jkl012

# ============================================================================
# Alertmanager Global Settings (Optional Override)
# ============================================================================
# These can override global settings in alertmanager.yml if needed

# Resolve timeout (default: 5m) - time after which firing alert is considered resolved
# ALERTMANAGER_RESOLVE_TIMEOUT=5m

# Alertmanager external URL (used in alert links)
# ALERTMANAGER_EXTERNAL_URL=https://alertmanager.example.com

# ============================================================================
# Common Alert Runbook and Dashboard URLs
# ============================================================================
# These can be referenced in alert annotations for quick access to documentation

# Base URL for runbooks (incident response procedures)
# RUNBOOK_BASE_URL=https://wiki.example.com/runbooks

# Base URL for dashboards (monitoring visualizations)
# DASHBOARD_BASE_URL=https://grafana.example.com/d

# ============================================================================
# Additional Optional Configuration
# ============================================================================

# Email receiver (if you want to add email notifications)
# SMTP_SMARTHOST=smtp.example.com:587
# SMTP_FROM=alertmanager@example.com
# SMTP_AUTH_USERNAME=your-email@example.com
# SMTP_AUTH_PASSWORD=your-email-password

# VictorOps (formerly Splunk On-Call) webhook (optional)
# VICTOROPS_WEBHOOK=https://alert.victorops.com/alerting/alert/...

# Opsgenie integration (optional)
# OPSGENIE_API_KEY=your-opsgenie-api-key
# OPSGENIE_API_URL=https://api.opsgenie.com

# ============================================================================
# Environment-specific settings
# ============================================================================

# Environment name (production, staging, development)
# ENVIRONMENT=production

# Alerting enabled (true/false)
# ALERTING_ENABLED=true

# Alert severity threshold (critical, warning, info)
# ALERT_SEVERITY_THRESHOLD=warning
