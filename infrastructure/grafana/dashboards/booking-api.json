{
  "title": "Booking API",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPS",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"booking-api\"}[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate 5xx",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]) / rate(http_server_requests_seconds_count[1m]) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate 4xx",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"4..\"}[1m]) / rate(http_server_requests_seconds_count[1m]) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM Heap",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", application=\"booking-api\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM Non-Heap",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\", application=\"booking-api\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HikariCP pool",
      "targets": [
        {
          "expr": "hikaricp_connections_active{pool=\"bookingApiPool\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Business",
      "targets": [
        {
          "expr": "increase(booking_created_total[5m])",
          "refId": "A"
        },
        {
          "expr": "increase(booking_cancelled_total[5m])",
          "refId": "B"
        }
      ]
    }
  ]
}